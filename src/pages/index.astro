---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title="Tiago Paes | Software Engineer" description="Software engineer focused on Laravel, PHP, and full-stack web development." hideHeader lang="en">
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white flex flex-col">
      <img class="rounded-full w-24 h-24 mb-2" src="https://avatars.githubusercontent.com/u/21131500?v=4" />
      <span>Tiago Paes</span>
      <span>Software Engineer</span>
    </h4>
    <div class="space-y-10">
      <section>
        <article class="space-y-2">
          <p class="animate">
            I’m a software engineer with 9+ years of experience, focused on full-stack web development and practical AI solutions.
          </p>

          <p class="animate">
            I build web applications, APIs, backend systems, and automation tools that help teams work more efficiently.
          </p>
        </article>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let&apos;s connect!
        </h5>
        <article>
          <p class="mb-4">
            Feel free to reach out on LinkedIn or send me an email:
          </p>
          <ul class="space-y-1">
            <li>
              LinkedIn: <Link href="https://www.linkedin.com/in/tiagopaees" external>linkedin.com/in/tiagopaees</Link>
            </li>
            <li>
              Email: <Link href="mailto:tiago@tiagopaes.dev">tiago@tiagopaes.dev</Link>
            </li>
          </ul>
        </article>
      </section>
    </div>
  </Container>
</PageLayout>
